@font-face {
  font-family: "Seesans";
  src: url("{{ 'Seesans-1.004.woff2' | file_url }}") format('woff2'),
  url("{{ 'Seesans-1.004.woff' | file_url }}") format('woff'),
  url("{{ 'Seesans-1.004.ttf' | file_url }}") format('truetype');
  font-display: swap;
}

@font-face {
  font-family: "Afacad";
  src: url("{{ 'Afacad-Regular.ttf' | asset_url }}") format('truetype');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

