        "text_UNbYqd": {
          "type": "text",
          "settings": {
            "text": "<p>Located between Hàng Cháo and Hàng Bột, SEESON exists as a quiet pause between the movement of Hàng Đẫy Stadium and the stillness of Văn Miếu – Quốc Tử Giám. Set within a renovated 1970s–80s house, the space preserves layers of its architectural memory. Raw textures and hand-finished details retain traces of the making process.</p>"
          }
        }
