        "collapsible_row_dDEBmt": {
          "type": "collapsible_row",
          "settings": {
            "heading": "PURCHASE POLICY",
            "font_body": true,
            "icon": "none",
            "row_content": "<p>SEESON offers free shipping for online orders within Vietnam (excluding exchange and return orders). For international orders, shipping fees will be calculated once complete delivery information has been provided.</p><p><strong>Estimated delivery times:</strong></p><ul><li>Inner districts of Hanoi: 1–2 business days</li><li>Outer districts of Hanoi and major cities: 2–3 business days</li><li>Other regions: 4–5 business days</li></ul><p>International orders: Customers may track their orders using the tracking number sent via email once the shipment has been dispatched, or contact <strong>support@seeson.vn</strong> for assistance.</p>",
            "page": ""
          }
        },
        "collapsible_row_PRnaRQ": {
          "type": "collapsible_row",
          "settings": {
            "heading": "RETURN POLICY",
            "font_body": true,
            "icon": "none",
            "row_content": "<p><strong>FOR DOMESTIC ORDERS (VIETNAM):</strong></p><ul><li><strong>Eligibility period:<br/></strong>Applicable <strong>once only within 07 days</strong> from the purchase date (for in-store purchases) or successful delivery date (for online orders).</li><li><strong>Product condition:<br/></strong>Returned products (including frames and demo lenses) must remain in original condition, free from damage, scratches or deformation, and include all original packaging.</li><li>Returns and exchanges do <strong>not</strong> apply to:</li><li>Lenses (including prescription lenses and SEESON sunglass lenses)</li><li>Promotional or discounted products</li></ul><p><em>*Please note: Orders that do not meet these requirements will be returned to the customer.</em></p><ul><li><strong>Price difference policy:</strong></li><li><strong>Exchange within the same product model (different color):</strong> Free exchange</li><li><strong>Exchange for a different product model:</strong> Pricing will be applied based on the product value at the time of exchange. If the exchanged item has a higher value than the original purchase (according to the invoice), customers are required to pay the difference. Conversely, if the exchanged item has a lower value, SEESON will refund the difference.</li></ul><p><strong>Examples:</strong></p><ul><li>Original item: $175; exchanged item: $200 → Additional payment required: $25</li><li>Original item: $200; exchanged item: $175 → Refund: $25</li></ul><p><strong>FOR INTERNATIONAL ORDERS:</strong></p><p>SEESON does not support direct exchanges. If customers wish to exchange for a different color or style, they are required to return the product for a full refund (to the original payment method or Paypal within 7 business days after the returned item passes quality inspection) and place a new order.</p>",
            "page": ""
          }
        },
        "collapsible_row_wbrPBx": {
          "type": "collapsible_row",
          "settings": {
            "heading": "RETURN & EXCHANGE PROCEDURE",
            "font_body": true,
            "icon": "none",
            "row_content": "<p><strong>FOR DOMESTIC ORDERS (VIETNAM):</strong></p><p>Please contact our Hotline at <strong>(+84) 986 009 390</strong>, Email at <strong>support@seeson.vn</strong>, or send a message via the SEESON Fanpage for detailed return/exchange instructions.</p><ul><li>Customers may bring the product directly to the original point of purchase or package and ship the item to the designated return address provided by SEESON.</li></ul><p>Important Notes:</p><ul><li>Cross-channel returns/exchanges are <strong>NOT</strong> applicable between online orders and purchases made at <strong>RUE MICHE L’ÉDITION</strong> or other authorized stockists.</li><li>Cross-channel returns/exchanges <strong>ARE</strong> applicable between online orders and purchases made at <strong>IRL FLAGSHIP</strong> stores.</li></ul><p><strong>FOR INTERNATIONAL ORDERS:</strong></p><p>Please contact <strong>support@seeson.vn</strong> or send a message via the SEESON Fanpage for return and exchange instructions.</p>",
            "page": ""
          }
        },
        "collapsible_row_q8E8mk": {
          "type": "collapsible_row",
          "settings": {
            "heading": "RETURN & EXCHANGE FEES",
            "font_body": true,
            "icon": "none",
            "row_content": "<ul><li><strong>In-store exchange:</strong> Complimentary</li><li><strong>Online returns/exchanges:<br/></strong>SEESON covers all shipping costs in cases where products have manufacturing defects. For returns or exchanges due to personal preference or other reasons, shipping costs will be borne by the customer.</li><li><strong>Demo lens surcharge:</strong> For returned or exchanged frames without the original demo lenses, an additional fee of <strong>50,000 VND</strong> applies (waived for lenses fitted at SEESON).</li></ul>",
            "page": ""
          }
        }
      },
