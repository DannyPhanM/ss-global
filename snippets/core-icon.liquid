{% comment %}
    Renders an icon based on the provided name.
    Accepts:
    - name: {String} Icon name (required)
    - class: {String} Custom classes (optional)
    - attr: {String} Custom attributes (optional)

    Usage:
    {% render 'core-icon', name: 'arrow' %}
{% endcomment %}

{%- liquid
  assign icon_name = name | default: ''
  assign icon_class = class | default: ''
  assign icon_attr = attr | default: ''
-%}

{%- case icon_name -%}
  {%- when 'arrow' -%}
    <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 100 40.12" class="{{ icon_class }}" {{ icon_attr }}>
      <path d="M100 0v11.52l-50 28.6L0 11.53V0l50 28.6z" fill="currentColor"/>
    </svg>

  {%- when 'wishlist' -%}
    <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 70 100.3" class="{{ icon_class }}" {{ icon_attr }}>
      <path d="M70 100.3 35 72.75 0 100.3V10.67C0 4.78 4.78 0 10.67 0h48.65c5.89 0 10.67 4.79 10.67 10.67v89.62ZM35 60.03l25 19.68V13c0-1.66-1.34-3-3-3H13c-1.66 0-3 1.34-3 3v66.7l25-19.68Z" fill="currentColor"/>
    </svg>

    {%- when 'wishlist-added' -%}
      <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 70 100.3" class="{{ icon_class }}" {{ icon_attr }}>
        <path d="M70 10.68v89.62L35 72.76 0 100.3V10.68C0 4.79 4.79 0 10.67 0h48.65C65.21 0 70 4.79 70 10.68" fill="currentColor"/>
      </svg>

  {%- when 'plus' -%}
    <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 90 90" class="{{ icon_class }}" {{ icon_attr }}>
      <path d="M90 40H50V0H40v40H0v10h40v40h10V50h40z" fill="currentColor"/>
    </svg>

  {%- when 'minus' -%}
    <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 90 10" class="{{ icon_class }}" {{ icon_attr }}>
      <path d="M0 0h90v10H0z" fill="currentColor"/>
    </svg>

  {% when 'cart' or 'cart-empty' %}
    <svg id="Layer_2" data-name="Layer 2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110 110">
      <defs>
        <style>
          .cls-1 {
            fill: none;
          }

          .cls-2 {
            fill: #231f20;
          }
        </style>
      </defs>
      <g id="v">
        <g>
          <rect class="cls-1" width="110" height="110"/>
          <path class="cls-2" d="M80,30v-5c0-13.79-11.21-25-25-25s-25,11.21-25,25v5h-15v80h80V30h-15ZM40,25c0-8.27,6.73-15,15-15s15,6.73,15,15v5h-30v-5ZM85,100H25v-60h60v60Z"/>
        </g>
      </g>
    </svg>

  {% when 'cart-new' or 'cart-empty-new' %}
    <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 110 110">
      <path d="M0 0h110v110H0z" style="fill:none"/>
      <path d="M80 30v-5C80 11.21 68.79 0 55 0S30 11.21 30 25v5H15v80h80V30zm-40-5c0-8.27 6.73-15 15-15s15 6.73 15 15v5H40zm45 75H25V40h60z" fill="currentColor"/>
    </svg>

  {% when 'close' %}
    <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 87.07 87.07" class="{{ icon_class }}" {{ icon_attr }}>
      <path d="M87.07 7.07 80 0 43.54 36.47 7.07 0 0 7.07l36.46 36.47L0 80l7.07 7.07 36.47-36.46L80 87.07 87.07 80 50.61 43.54z" fill="currentColor"/>
    </svg>
  
  {% when 'close-filter' %}
    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ icon_class }}" {{ icon_attr }}>
      <path d="M2.29189 1.75903L8.18445 7.65159L7.59519 8.24085L1.70264 2.34829L2.29189 1.75903Z" fill="#999999"/>
      <path d="M7.70856 1.75903L1.816 7.65159L2.40526 8.24085L8.29781 2.34829L7.70856 1.75903Z" fill="#999999"/>
    </svg>

  {% when 'filter' %}
    <svg xmlns="http://www.w3.org/2000/svg" id="Layer_2" data-name="Layer 2" viewBox="0 0 100 100" class="{{ icon_class }}" {{ icon_attr }}>
      <defs/>
      <g id="v">
        <path d="M20 0h10v50H20zM0 70h20v30h10V70h20V60H0zM70 50h10v50H70zM80 30V0H70v30H50v10h50V30z" fill="currentColor"/>
      </g>
    </svg>

  {% when 'menu' %}
    <svg id="Layer_2" data-name="Layer 2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110 110">
      <defs>
        <style>
          .cls-1 {
            fill: none;
          }

          .cls-2 {
            fill: #231f20;
          }
        </style>
      </defs>
      <g id="v">
        <g>
          <rect class="cls-1" width="110" height="110"/>
          <g>
            <rect class="cls-2" x="5" y="20" width="100" height="10"/>
            <rect class="cls-2" x="5" y="55" width="100" height="10"/>
            <rect class="cls-2" x="5" y="90" width="100" height="10"/>
          </g>
        </g>
      </g>
    </svg>

  {%  when 'menu-new' %}
    <svg xmlns="http://www.w3.org/2000/svg" id="Layer_2" data-name="Layer 2" viewBox="0 0 110 110"  class="{{ icon_class }}">
  <defs/>
  <g id="v">
    <path d="M0 0h110v110H0z" style="fill:none"/>
    <path d="M5 20h100v10H5zM5 55h100v10H5zM5 90h100v10H5z" class="cls-2"/>
  </g>
</svg>

  {% when 'search' %}
    <svg id="Layer_2" data-name="Layer 2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 110 110">
      <defs>
        <style>
          .cls-1 {
            fill: none;
          }

          .cls-2 {
            fill: #231f20;
          }
        </style>
      </defs>
      <g id="v">
        <g>
          <rect class="cls-1" width="110" height="110"/>
          <path class="cls-2" d="M104.99,102.92l-36.97-36.97c4.38-5.85,6.98-13.1,6.98-20.95,0-19.3-15.7-35-35-35S5,25.7,5,45s15.7,35,35,35c7.85,0,15.1-2.6,20.95-6.98l36.97,36.97,7.07-7.07ZM15,45c0-13.79,11.21-25,25-25s25,11.21,25,25-11.21,25-25,25-25-11.21-25-25Z"/>
        </g>
      </g>
    </svg>

  {% when 'search-new' %}
    <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 110 110" class="{{ icon_class }} test">
      <path d="M0 0h110v110H0z" style="fill:none"/>
      <path d="M104.99 102.92 68.02 65.95C72.4 60.1 75 52.85 75 45c0-19.3-15.7-35-35-35S5 25.7 5 45s15.7 35 35 35c7.85 0 15.1-2.6 20.95-6.98l36.97 36.97zM15 45c0-13.79 11.21-25 25-25s25 11.21 25 25-11.21 25-25 25-25-11.21-25-25" fill="currentColor"/>
    </svg>
    
  {% when 'trash' or 'remove' %}
    <svg xmlns="http://www.w3.org/2000/svg" id="Layer_2" data-name="Layer 2" viewBox="0 0 100 100" class="{{ icon_class }}" {{ icon_attr }}>
      <defs/>
      <g id="v">
        <path d="M100 10H70V0H30v10H0v10h15v80h70V20h15zM75 90H25V20h50z" fill="currentColor"/>
        <path d="M35 30h10v50H35zM55 30h10v50H55z" fill="currentColor"/>
      </g>
    </svg>

  {% when 'rotate' %}
    <svg xmlns="http://www.w3.org/2000/svg" data-name="Layer 2" viewBox="0 0 100 57.59" class="{{ icon_class }}" {{ icon_attr }}>
      <path d="m70.36 9.6.82-9.6L42.5 12.59l26.12 17.3.88-10.19c12.91 3 20.51 8.62 20.51 12.89 0 3.11-3.91 6.78-10.21 9.58-7.88 3.5-18.46 5.42-29.79 5.42-24.42 0-40-8.88-40-15 0-3.1 3.91-6.77 10.21-9.57 2.92-1.3 6.22-2.39 9.79-3.23V9.52C12.02 13.24 0 21.93 0 32.59c0 14.26 21.49 25 50 25s50-10.74 50-25C100 22 88.14 13.35 70.36 9.6" fill="currentColor"/>
    </svg>

  {% when 'checkmark' %}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="{{ icon_class }}" viewBox="0 0 12 9" {{ icon_attr }}>
      <path fill="currentColor" fill-rule="evenodd" d="M11.35.643a.5.5 0 0 1 .006.707l-6.77 6.886a.5.5 0 0 1-.719-.006L.638 4.845a.5.5 0 1 1 .724-.69l2.872 3.011 6.41-6.517a.5.5 0 0 1 .707-.006z" clip-rule="evenodd"/>
    </svg>

  {% when 'error' %}
    <svg class="{{ icon_class }}" viewBox="0 0 13 13" {{ icon_attr }}>
      <circle cx="6.5" cy="6.5" r="5.5" stroke="currentColor" stroke-width="2" fill="none"/>
      <circle cx="6.5" cy="6.5" r="5.5" fill="currentColor" stroke="currentColor" stroke-width=".7"/>
      <path fill="white" d="m5.874 3.528.1 4.044h1.053l.1-4.044zm.627 6.133c.38 0 .68-.288.68-.656s-.3-.656-.68-.656-.681.288-.681.656.3.656.68.656"/>
    </svg>

  {% when 'success' %}
    <svg class="{{ icon_class }}" viewBox="0 0 13 13" {{ icon_attr }}>
      <path fill="currentColor" stroke="white" stroke-width=".7" d="M6.5 12.35a5.85 5.85 0 1 0 0-11.7 5.85 5.85 0 0 0 0 11.7Z"/>
      <path stroke="white" d="m5.533 8.664 3.72-3.982M4.106 6.769l2.032 1.857"/>
    </svg>

  {% when 'caret' %}
    <svg class="{{ icon_class }}" viewBox="0 0 10 6" {{ icon_attr }}>
      <path fill="currentColor" fill-rule="evenodd" d="M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 0 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708" clip-rule="evenodd"/>
    </svg>

  {% when 'zoom' %}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="{{ icon_class }}" viewBox="0 0 19 19" {{ icon_attr }}>
      <path fill="currentColor" fill-rule="evenodd" d="M4.667 7.94a.5.5 0 0 1 .499-.501l5.534-.014a.5.5 0 1 1 .002 1l-5.534.014a.5.5 0 0 1-.5-.5" clip-rule="evenodd"/><path fill="currentColor" fill-rule="evenodd" d="M7.926 4.665a.5.5 0 0 1 .501.498l.014 5.534a.5.5 0 1 1-1 .003l-.014-5.534a.5.5 0 0 1 .499-.501" clip-rule="evenodd"/><path fill="currentColor" fill-rule="evenodd" d="M12.832 3.03a6.931 6.931 0 1 0-9.802 9.802 6.931 6.931 0 0 0 9.802-9.802M2.323 2.323a7.931 7.931 0 0 1 11.296 11.136l4.628 4.628a.5.5 0 0 1-.707.707l-4.662-4.662A7.932 7.932 0 0 1 2.323 2.323" clip-rule="evenodd"/>
    </svg>

  {% when 'play' %}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="{{ icon_class }}" viewBox="0 0 10 14" {{ icon_attr }}>
      <path fill="currentColor" fill-rule="evenodd" d="M1.482.815A1 1 0 0 0 0 1.69v10.517a1 1 0 0 0 1.525.851L10.54 7.5a1 1 0 0 0-.043-1.728z" clip-rule="evenodd"/>
    </svg>

  {% when '3d-model' %}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="{{ icon_class }}" viewBox="0 0 18 21" {{ icon_attr }}>
      <path fill="currentColor" d="m7.68 20.629-6.4-3.906A2.71 2.71 0 0 1 0 14.405v-7.81a2.72 2.72 0 0 1 1.278-2.318l6.4-3.9a2.52 2.52 0 0 1 2.644-.003l6.4 3.9A2.72 2.72 0 0 1 18 6.6v7.809a2.71 2.71 0 0 1-1.279 2.318l-6.4 3.906A2.54 2.54 0 0 1 9 21a2.54 2.54 0 0 1-1.32-.371M8.724 2.078l-6.4 3.9a.71.71 0 0 0-.321.612v7.81a.71.71 0 0 0 .32.61L8 18.48v-7.561a1.77 1.77 0 0 1 .934-1.555l6.512-3.523L9.28 2.08a.52.52 0 0 0-.556-.002"/>
    </svg>

  {% when 'square' %}
    <svg class="{{ icon_class }}" width="16" height="16" viewBox="0 0 16 16" {{ icon_attr }}>
      <rect width="16" height="16" fill="none" stroke="currentColor"/>
    </svg>

  {% when 'unavailable' %}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="{{ icon_class }}" viewBox="0 0 20 20" {{ icon_attr }}>
      <path fill="currentColor" stroke="white" d="M13.94 3.94 10 7.878l-3.94-3.94A1.499 1.499 0 1 0 3.94 6.06L7.88 10l-3.94 3.94a1.499 1.499 0 1 0 2.12 2.12L10 12.12l3.94 3.94a1.497 1.497 0 0 0 2.12 0 1.5 1.5 0 0 0 0-2.12L12.122 10l3.94-3.94a1.499 1.499 0 1 0-2.121-2.12z"/>
    </svg>

  {% when 'info' %}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="{{ icon_class }}" viewBox="0 0 15 14" {{ icon_attr }}>
      <path fill="currentColor" fill-opacity=".75" fill-rule="evenodd" d="M14.5 7a7 7 0 1 1-14 0 7 7 0 0 1 14 0m-7 6.174A6.174 6.174 0 1 0 7.5.826a6.174 6.174 0 0 0 0 12.348" clip-rule="evenodd"/><path fill="currentColor" fill-opacity=".75" fill-rule="evenodd" d="M8.192 3.554c0-.39-.276-.725-.69-.725-.41 0-.696.329-.696.725 0 .392.29.719.696.719.411 0 .69-.332.69-.72" clip-rule="evenodd"/><path fill="currentColor" fill-opacity=".75" d="M6.971 5.724a.33.33 0 0 1 .33-.33H7.7a.33.33 0 0 1 .33.33v5.123a.33.33 0 0 1-.33.33h-.397a.33.33 0 0 1-.33-.33z"/>
    </svg>

  {% when 'discount' %}
    <svg class="{{ icon_class }}" viewBox="0 0 12 12" {{ icon_attr }}>
      <path fill="currentColor" fill-rule="evenodd" d="M7 0h3a2 2 0 0 1 2 2v3a1 1 0 0 1-.3.7l-6 6a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 0-1.4l6-6A1 1 0 0 1 7 0m2 2a1 1 0 1 0 2 0 1 1 0 0 0-2 0" clip-rule="evenodd"/>
    </svg>

  {% when 'account' %}
    <svg class="{{ icon_class }}" aria-hidden="true" fill="none" focusable="false" width="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" {{ icon_attr }}>
      <path d="M16.1255 7.75C15.9415 10.228 14.0625 12.25 12.0005 12.25C9.93847 12.25 8.05647 10.229 7.87547 7.75C7.68847 5.172 9.51547 3.25 12.0005 3.25C14.4845 3.25 16.3135 5.219 16.1255 7.75Z" stroke-linecap="round" stroke-linejoin="round"></path>
      <path d="M3.0166 21.747C3.7826 17.5 7.9216 15.25 11.9996 15.25C16.0776 15.25 20.2166 17.5 20.9836 21.747" stroke-miterlimit="10"></path>
    </svg>

  {% when 'reset' %}
    <svg fill="none" stroke="currentColor" class="{{ icon_class }}" viewBox="0 0 18 18" {{ icon_attr }}><circle cx="9" cy="9" r="8.5" stroke-opacity=".2"/><path stroke-linecap="round" stroke-linejoin="round" d="M11.83 11.83 6.172 6.17M6.229 11.885l5.544-5.77"/></svg>

  {% when 'share' %}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="{{ icon_class }}" viewBox="0 0 13 12" {{ icon_attr }}>
      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M1.625 8.125v2.167a1.083 1.083 0 0 0 1.083 1.083h7.584a1.083 1.083 0 0 0 1.083-1.083V8.125"/><path fill="currentColor" fill-rule="evenodd" d="M6.148 1.271a.5.5 0 0 1 .707 0L9.563 3.98a.5.5 0 0 1-.707.707L6.501 2.332 4.147 4.687a.5.5 0 1 1-.708-.707z" clip-rule="evenodd"/><path fill="currentColor" fill-rule="evenodd" d="M6.5 1.125a.5.5 0 0 1 .5.5v6.5a.5.5 0 0 1-1 0v-6.5a.5.5 0 0 1 .5-.5" clip-rule="evenodd"/>
    </svg>

  {% when 'copy' %}
    <svg class="{{ icon_class }}" width="11" height="13" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" viewBox="0 0 11 13" {{ icon_attr }}>
      <path fill-rule="evenodd" clip-rule="evenodd" d="M2 1a1 1 0 011-1h7a1 1 0 011 1v9a1 1 0 01-1 1V1H2zM1 2a1 1 0 00-1 1v9a1 1 0 001 1h7a1 1 0 001-1V3a1 1 0 00-1-1H1zm0 10V3h7v9H1z" fill="currentColor"/>
    </svg>
    
  {% when 'facebook' %}
    <svg class="{{ icon_class }}" viewBox="0 0 20 20" {{ icon_attr }}><path fill="currentColor" d="M18 10.049C18 5.603 14.419 2 10 2s-8 3.603-8 8.049C2 14.067 4.925 17.396 8.75 18v-5.624H6.719v-2.328h2.03V8.275c0-2.017 1.195-3.132 3.023-3.132.874 0 1.79.158 1.79.158v1.98h-1.009c-.994 0-1.303.621-1.303 1.258v1.51h2.219l-.355 2.326H11.25V18c3.825-.604 6.75-3.933 6.75-7.951"/></svg>

  {% when 'instagram' %}
    <svg class="{{ icon_class }}" viewBox="0 0 20 20" {{ icon_attr }}><path fill="currentColor" fill-rule="evenodd" d="M13.23 3.492c-.84-.037-1.096-.046-3.23-.046-2.144 0-2.39.01-3.238.055-.776.027-1.195.164-1.487.273a2.4 2.4 0 0 0-.912.593 2.5 2.5 0 0 0-.602.922c-.11.282-.238.702-.274 1.486-.046.84-.046 1.095-.046 3.23s.01 2.39.046 3.229c.004.51.097 1.016.274 1.495.145.365.319.639.602.913.282.282.538.456.92.602.474.176.974.268 1.479.273.848.046 1.103.046 3.238.046s2.39-.01 3.23-.046c.784-.036 1.203-.164 1.486-.273.374-.146.648-.329.921-.602.283-.283.447-.548.602-.922.177-.476.27-.979.274-1.486.037-.84.046-1.095.046-3.23s-.01-2.39-.055-3.229c-.027-.784-.164-1.204-.274-1.495a2.4 2.4 0 0 0-.593-.913 2.6 2.6 0 0 0-.92-.602c-.284-.11-.703-.237-1.488-.273ZM6.697 2.05c.857-.036 1.131-.045 3.302-.045a63 63 0 0 1 3.302.045c.664.014 1.321.14 1.943.374a4 4 0 0 1 1.414.922c.41.397.728.88.93 1.414.23.622.354 1.279.365 1.942C18 7.56 18 7.824 18 10.005c0 2.17-.01 2.444-.046 3.292-.036.858-.173 1.442-.374 1.943-.2.53-.474.976-.92 1.423a3.9 3.9 0 0 1-1.415.922c-.51.191-1.095.337-1.943.374-.857.036-1.122.045-3.302.045-2.171 0-2.445-.009-3.302-.055-.849-.027-1.432-.164-1.943-.364a4.15 4.15 0 0 1-1.414-.922 4.1 4.1 0 0 1-.93-1.423c-.183-.51-.329-1.085-.365-1.943C2.009 12.45 2 12.167 2 10.004c0-2.161 0-2.435.055-3.302.027-.848.164-1.432.365-1.942a4.4 4.4 0 0 1 .92-1.414 4.2 4.2 0 0 1 1.415-.93c.51-.183 1.094-.33 1.943-.366Zm.427 4.806a4.105 4.105 0 1 1 5.805 5.805 4.105 4.105 0 0 1-5.805-5.805m1.882 5.371a2.668 2.668 0 1 0 2.042-4.93 2.668 2.668 0 0 0-2.042 4.93m5.922-5.942a.958.958 0 1 1-1.355-1.355.958.958 0 0 1 1.355 1.355" clip-rule="evenodd"/></svg>

  {% when 'youtube' %}
    <svg class="{{ icon_class }}" viewBox="0 0 20 20" {{ icon_attr }}><path fill="currentColor" d="M18.16 5.87c.34 1.309.34 4.08.34 4.08s0 2.771-.34 4.08a2.13 2.13 0 0 1-1.53 1.53c-1.309.34-6.63.34-6.63.34s-5.321 0-6.63-.34a2.13 2.13 0 0 1-1.53-1.53c-.34-1.309-.34-4.08-.34-4.08s0-2.771.34-4.08a2.17 2.17 0 0 1 1.53-1.53C4.679 4 10 4 10 4s5.321 0 6.63.34a2.17 2.17 0 0 1 1.53 1.53M8.3 12.5l4.42-2.55L8.3 7.4z"/></svg>

  {% when 'tiktok' %}
    <svg class="{{ icon_class }}" viewBox="0 0 20 20" {{ icon_attr }}><path fill="currentColor" d="M10.511 1.705h2.74s-.157 3.51 3.795 3.768v2.711s-2.114.129-3.796-1.158l.028 5.606A5.073 5.073 0 1 1 8.213 7.56h.708v2.785a2.298 2.298 0 1 0 1.618 2.205z"/></svg>

  {% when 'twitter' %}
