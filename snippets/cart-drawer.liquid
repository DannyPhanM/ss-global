{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }

  .drawer__header {
    display: flex;
    align-items: center;
    padding: 20px 0 57px;
    margin: 0;
  }

  .drawer__tabs {
    display: flex;
    gap: 2rem;
    flex-grow: 1;
  }

  .drawer__tab {
    background: none;
    border: none;
    padding: 0;
    font-size: 2.2rem;
    font-weight: 600;
    font-family: var(--font-body-family);
    line-height: 1.2;
    text-transform: uppercase;
    cursor: pointer;
    color: rgba(var(--color-foreground), 0.5);
    position: relative;
    transition: color 0.3s ease;
  }

  .drawer__tab[data-tab="wishlist"] {
    margin-left: 11px;
  }

  cart-drawer[active-tab="cart"] .drawer__tab[data-tab="cart"],
  cart-drawer[active-tab="wishlist"] .drawer__tab[data-tab="wishlist"],
  cart-drawer:not([active-tab]) .drawer__tab[data-tab="cart"] {
    color: rgb(var(--color-foreground));
  }


  .drawer__tab-count {
    font-size: 1.2rem;
    vertical-align: super;
    margin-left: 0.2rem;
  }

  cart-drawer:not([active-tab="wishlist"]) .drawer__wishlist-content {
    display: none !important;
  }

  cart-drawer[active-tab="wishlist"] .drawer__cart-content,
  cart-drawer[active-tab="wishlist"] .drawer__footer {
    display: none !important;
  }

  .drawer__wishlist-content {
    flex-grow: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .drawer__wishlist-content .drawer__contents {
    overflow-y: auto;
    flex-grow: 1;
    height: 100%;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.2) transparent;
  }

  {% comment %} .drawer__wishlist-content .drawer__contents {
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: center;
  } {% endcomment %}

  .drawer__wishlist-content .drawer__contents::-webkit-scrollbar {
    width: 3px;
    display: block;
  }

  .drawer__wishlist-content .drawer__contents::-webkit-scrollbar-thumb {
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: 100px;
  }

  .totals-summary {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .totals-summary__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .totals-summary__label {
    font-size: 14px !important;
    font-weight: 500 !important;
    line-height: 1.2 !important;
    letter-spacing: 0.09px !important;
    text-transform: capitalize !important;
    color: #000;
  }

  .totals-summary__value {
    font-size: 1.4rem;
    font-weight: 500;
    color: #000;
    letter-spacing: 0.7px;
  }

  .totals-summary__item--total .totals-summary__label,
  .totals-summary__item--total .totals-summary__value {
    font-size: 1.6rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    text-transform: uppercase;
  }

  .totals-summary__item--discount .totals-summary__value {
    color: #000;
    letter-spacing: 0.7px;
  }

  .drawer__wishlist-content.empty #WishlistDrawerContent {
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: center;
    margin-top: 0;
  }
</style>



<script>
  document.addEventListener('DOMContentLoaded', () => {
    const drawer = document.querySelector('cart-drawer');
    if (!drawer) return;

    if (!drawer.hasAttribute('active-tab')) {
      drawer.setAttribute('active-tab', 'cart');
    }

    if (drawer) {
      const originalOpen = drawer.open;
      if (typeof originalOpen === 'function') {
        drawer.open = function(triggeredBy) {
          originalOpen.call(this, triggeredBy);
          if (window._swat) {
            updateWishlistCount(window._swat);
            if (typeof window._swat.initializeActionButtons === 'function') {
              window._swat.initializeActionButtons('#CartDrawer');
            }
          }
        };
      }

      const originalRenderContents = drawer.renderContents;
      if (typeof originalRenderContents === 'function') {
        drawer.renderContents = function(parsedState) {
          originalRenderContents.call(this, parsedState);
          if (window._swat) {
            updateWishlistCount(window._swat);
            if (typeof window._swat.initializeActionButtons === 'function') {
              window._swat.initializeActionButtons('#CartDrawer');
            }
          }
        };
      }
    }

    const checkEmptyWishlist = () => {
      const counterEl = document.querySelector('.wishlist-count-js');
      const wishlistContent = document.querySelector('.drawer__wishlist-content');
      if (counterEl && wishlistContent) {
        const text = counterEl.textContent.trim();
        const countMatch = text.match(/\d+/);
        const count = countMatch ? parseInt(countMatch[0], 10) : 0;
        if (count === 0) {
          wishlistContent.classList.add('empty');
        } else {
          wishlistContent.classList.remove('empty');
        }
      }
    };

    const checkWishlistTitleLines = () => {
      const wishlistItems = document.querySelectorAll('.swym-wishlist-item');
      wishlistItems.forEach(item => {
        const titleEl = item.querySelector('.swym-title');
        if (titleEl) {
          const rect = titleEl.getBoundingClientRect();
          const height = rect.height;
          if (height > 0) {
            const computedStyle = window.getComputedStyle(titleEl);
            const lh = parseFloat(computedStyle.lineHeight) || 16;
            if (height > lh * 1.3) {
              item.classList.add('line-two');
            } else {
              item.classList.remove('line-two');
            }
          }
        }
      });
    };

    const checkWishlistStock = () => {
      const container = document.querySelector('#swym-wishlist-render-container');
      if (!container) return;

      const items = container.querySelectorAll('.swym-wishlist-item:not([data-stock-checked])');
      if (items.length === 0) return;

      window._wishlistStockCache = window._wishlistStockCache || {};

      items.forEach(async (item) => {
        item.setAttribute('data-stock-checked', 'true');

        const linkEl = item.querySelector('a[href*="/products/"]');
        if (!linkEl) return;

        try {
          const url = new URL(linkEl.href, window.location.origin);
          const pathParts = url.pathname.split('/');
          const handle = pathParts[pathParts.length - 1];
          const variantId = url.searchParams.get('variant');

          if (!handle || !variantId) return;

          let productData = window._wishlistStockCache[handle];
          if (!productData) {
            const response = await fetch(`/products/${handle}.js`);
            if (!response.ok) return;
            productData = await response.json();
            window._wishlistStockCache[handle] = productData;
          }

          const variant = productData.variants.find(v => String(v.id) === String(variantId));
          if (variant && !variant.available) {
            const btn = item.querySelector('.swym-add-to-cart-btn');
            if (btn) {
              btn.classList.add('swym-out-of-stock');
              btn.setAttribute('disabled', 'disabled');
            }
          }
        } catch (err) {
          console.error('Error checking wishlist stock:', err);
        }
      });
    };

    checkEmptyWishlist();
    checkWishlistTitleLines();

    const observer = new MutationObserver(() => {
      const buttons = document.querySelectorAll('#CartDrawer .swym-bookmark:not(.swym-custom-initialized)');
      if (buttons.length > 0 && window._swat) {
        buttons.forEach(btn => btn.classList.add('swym-custom-initialized'));
        
        if (typeof window._swat.initializeActionButtons === 'function') {
          window._swat.initializeActionButtons('#CartDrawer');
        }
      }

      if (window._swat) {
        const counter = document.querySelector('.wishlist-count-js');
        if (counter && counter.dataset.synced !== "true") {
          counter.dataset.synced = "true";
          updateWishlistCount(window._swat);
        }
      }

      checkEmptyWishlist();
      checkWishlistTitleLines();
      checkWishlistStock();
    });
    observer.observe(drawer, { childList: true, subtree: true, characterData: true });

    function updateWishlistCount(swat) {
      if (swat && typeof swat.fetchWrtEventTypeET === 'function') {
        swat.fetchWrtEventTypeET(function(products) {
          if (!Array.isArray(products)) return;
          var validItems = products.filter(function(item) {
            return item.d !== 1 && item.source !== "auto-wishlist";
          });
          var count = validItems.length;
          const countElements = document.querySelectorAll('.wishlist-count-js');
          countElements.forEach(el => {
            el.textContent = count;
            el.dataset.synced = "true";
            if (count > 0) {
              el.classList.add("has-items");
            } else {
              el.classList.remove("has-items");
            }
          });

          const wishlistContent = document.querySelector('.drawer__wishlist-content');
          if (wishlistContent) {
            if (count === 0) {
              wishlistContent.classList.add('empty');
            } else {
              wishlistContent.classList.remove('empty');
            }
          }
        }, 4);
      } else if (swat && swat.wishlist && typeof swat.wishlist.fetchUserLists === 'function') {
        swat.wishlist.fetchUserLists(function(lists) {
          if (!Array.isArray(lists)) return;
          const defaultList = lists.find(list => list.isDefault) || lists[0];
          const count = defaultList ? defaultList.itemCount : 0;
          const countElements = document.querySelectorAll('.wishlist-count-js');
          countElements.forEach(el => {
            el.textContent = count;
            if (count > 0) {
              el.classList.add("has-items");
            } else {
              el.classList.remove("has-items");
            }
          });

          const wishlistContent = document.querySelector('.drawer__wishlist-content');
          if (wishlistContent) {
            if (count === 0) {
              wishlistContent.classList.add('empty');
            } else {
              wishlistContent.classList.remove('empty');
            }
          }
        }, function(error) {
          console.error("Error fetching wishlist count:", error);
        });
      }
    }

    function refreshCartDrawer() {
      fetch('/cart?sections=cart-drawer,cart-icon-bubble')
        .then(response => response.json())
        .then(sections => {
          const drawer = document.querySelector('cart-drawer');
          if (drawer) {
            drawer.renderContents({ sections: sections });
            
            // Nếu người dùng đang ở tab wishlist, cần vẽ lại danh sách wishlist lập tức!
            const activeTab = drawer.getAttribute('active-tab');
            if (activeTab === 'wishlist' && window._swat) {
              refreshSwymWishlist(window._swat);
            }
          }
        })
        .catch(err => console.error('Error refreshing cart drawer:', err));
    }

    function refreshSwymWishlist(swatInstance) {
      updateWishlistCount(swatInstance);
      const wishlistContainerElement = document.querySelector("#swym-wishlist-render-container");
      if (wishlistContainerElement) {
        wishlistContainerElement.innerHTML = '';
        const queryParams = swatInstance.utils.getEncodedAsObject(window.location.search);
        
        {% if request.locale.iso_code != 'en' %}
        const observer = new MutationObserver((mutations, obs) => {
          const emptyContainer = wishlistContainerElement.querySelector('.swym-empty-wishlist-container');
          if (emptyContainer && !emptyContainer.querySelector('.custom-empty-wishlist')) {
            const customHtml = document.createElement('div');
            customHtml.className = 'custom-empty-wishlist';
            customHtml.innerHTML = `
              <p class="swym-empty-wishlist-text swym-text swym-text-1" style="text-align: center;">Danh sách yêu thích lưu lại những thiết kế đã chọn</p>
              <button class="swym-empty-wishlist-continue-btn swym-button swym-button-1 swym-is-button swym-bg-2 swym-color-4" onclick="window.location.href='/collections/all'" role="button" aria-label="Continue shopping" data-handled="true">TIẾP TỤC MUA SẮM</button>
              <style>
                .custom-empty-wishlist {
                  text-align: center;
                }
                /* Ẩn các element mặc định của Swym đi, chỉ chừa lại cái của mình */
                .swym-empty-wishlist-container > *:not(.custom-empty-wishlist) {
                  display: none !important;
                }
              </style>
            `;
            emptyContainer.appendChild(customHtml);
          }
        });
        observer.observe(wishlistContainerElement, { childList: true, subtree: true });
        {% endif %}
        
        swatInstance.ui.renderWishlistInContainer(wishlistContainerElement, queryParams);
      }
    }
    
    drawer.addEventListener('click', (event) => {
      const tab = event.target.closest('.drawer__tab');
      if (!tab) return;
      
      const target = tab.dataset.tab;
      drawer.setAttribute('active-tab', target);

      if (target === 'wishlist' && window._swat) {
        refreshSwymWishlist(window._swat);
      }
    });

    function initSwymWishlist(swat) {
      window._swat = swat;

      refreshSwymWishlist(swat);
      if (typeof swat.initializeActionButtons === 'function') {
        swat.initializeActionButtons('#CartDrawer');
      }

      swat.evtLayer.addEventListener('sw:addedtowishlist', () => {
        refreshSwymWishlist(swat);
        setTimeout(() => refreshSwymWishlist(swat), 100);
        setTimeout(() => refreshSwymWishlist(swat), 500);
      });
      swat.evtLayer.addEventListener('sw:removedfromwishlist', () => {
        refreshSwymWishlist(swat);
        setTimeout(() => refreshSwymWishlist(swat), 100);
        setTimeout(() => refreshSwymWishlist(swat), 500);
      });
      
      document.addEventListener("swym:added", () => {
        refreshSwymWishlist(swat);
        setTimeout(() => refreshSwymWishlist(swat), 100);
        setTimeout(() => refreshSwymWishlist(swat), 500);
      });
      document.addEventListener("swym:removed", () => {
        refreshSwymWishlist(swat);
        setTimeout(() => refreshSwymWishlist(swat), 100);
        setTimeout(() => refreshSwymWishlist(swat), 500);
      });
      
      swat.evtLayer.addEventListener('sw:addedtocart', () => {
        refreshCartDrawer();
      });
      swat.evtLayer.addEventListener('sw:addedalltocart', () => {
        refreshCartDrawer();
      });

      if (swat.JSEvents && swat.JSEvents.customerInfoRefreshed) {
        swat.evtLayer.addEventListener(swat.JSEvents.customerInfoRefreshed, () => updateWishlistCount(swat));
      }
    }

    if (window._swat) {
      initSwymWishlist(window._swat);
    } else {
      window.SwymCallbacks = window.SwymCallbacks || [];
      window.SwymCallbacks.push(initSwymWishlist);
    }
  });
</script>
<script class="swym-wishlist-header-counter-custom">
function renderWishlistCounter(swat) {
  var counterElems = document.querySelectorAll(".swym-wishlist-header-counter");
  if (!counterElems.length) return;

  function updateCount() {
    swat.fetchWrtEventTypeET(function(products){

      var validItems = products.filter(function(item){
        return item.d !== 1 && item.source !== "auto-wishlist";
      });

      var count = validItems.length;

      counterElems.forEach(function(el){
        el.innerText = count;

        if (count > 0) {
          el.classList.add("has-items");
        } else {
          el.classList.remove("has-items");
        }
      });

      const wishlistContent = document.querySelector('.drawer__wishlist-content');
      if (wishlistContent) {
        if (count === 0) {
          wishlistContent.classList.add('empty');
        } else {
          wishlistContent.classList.remove('empty');
        }
      }

    }, 4);
  }

  updateCount();

  document.addEventListener("swym:added", updateCount);
  document.addEventListener("swym:removed", updateCount);
}

window.SwymCallbacks = window.SwymCallbacks || [];
window.SwymCallbacks.push(renderWishlistCounter);
</script>


<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >

        <div class="drawer__header">
          <div class="drawer__tabs">
            <button class="drawer__tab" data-tab="cart" type="button">
              {{ 'sections.cart.title' | t }}
              <span class="drawer__tab-count">({{ cart.item_count }})</span>
            </button>

            <button class="drawer__tab" data-tab="wishlist" type="button">
              {{ 'general.wishlist.title' | t | default: 'Wishlist' }}
              <span class="swym-wishlist-header-counter drawer__tab-count wishlist-count-js"></span>
              <span class="swym-storefront-layout-tab-count"></span>
            </button>
          </div>
          <button
            class="drawer__close"
            type="button"
            onclick="this.closest('cart-drawer').close()"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <span class="svg-wrapper">{% render 'core-icon', name: 'close', class: 'icon icon-close' %}</span>
          </button>
        </div>

      <div class="drawer__cart-content">
        {%- if cart == empty -%}
          <div class="drawer__inner-empty">
            <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
              <div class="cart-drawer__empty-content">
                <p class="cart__empty-text"> {{ 'sections.cart.empty' | t }} </p>
                <a href="/collections/view-all-sun" class="button button--primary continue-shopping-button">
                  {{ 'general.continue_shopping' | t }}
                </a>
              </div>
            </div>
          </div>
        {%- endif -%}


      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty"
        {% endif %}
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">
                  <thead role="rowgroup">
                    <tr role="row">
                      <th id="CartDrawer-ColumnProductImage" role="columnheader">
                        <span class="visually-hidden">{{ 'sections.cart.headings.image' | t }}</span>
                      </th>
                      <th
                        id="CartDrawer-ColumnProduct"
                        class="caption-with-letter-spacing"
                        scope="col"
                        role="columnheader"
                      >
                        {{ 'sections.cart.headings.product' | t }}
                      </th>
                      <th
                        id="CartDrawer-ColumnTotal"
                        class="right caption-with-letter-spacing"
                        scope="col"
                        role="columnheader"
                      >
                        {{ 'sections.cart.headings.total' | t }}
                      </th>
                      <th id="CartDrawer-ColumnQuantity" role="columnheader">
                        <span class="visually-hidden">{{ 'sections.cart.headings.quantity' | t }}</span>
                      </th>
                    </tr>
                  </thead>

                  <tbody role="rowgroup">
                    {%- for item in cart.items -%}
                      <tr
                        id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                        class="cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                        role="row"
                        {% if item.parent_relationship.parent != null %}
                          aria-label="{{- 'products.product.nested_label' | t: title: item.product.title, parent_title: item.parent_relationship.parent.title | escape -}}"
                        {% endif %}
                      >
                        <td
                          class="cart-item__media"
                          role="cell"
                          headers="CartDrawer-ColumnProductImage"
                        >
                          {% if item.image %}
                            {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                            <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                            <div class="cart-item__image-container gradient">
                              <img
                                class="cart-item__image"
                                src="{{ item.image | image_url: width: 300 }}"
                                alt="{{ item.image.alt | escape }}"
                                loading="lazy"
                                width="155"
                                height="72"
                              >
                            </div>
                          {% endif %}
                        </td>

                        <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                                                                                {%- if settings.show_vendor -%}
                            <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                          {%- endif -%}

                          <a href="{{ item.url }}" class="cart-item__name h4 break">
                            {{- item.product.title | escape -}}
                          </a>
                          <div class="cart-item__details-wrapper">


                          {%- if item.product.has_only_default_variant == false
                            or item.properties.size != 0
                            or item.selling_plan_allocation != null
                          -%}
                            <dl>
                              {%- if item.product.has_only_default_variant == false -%}
                                {%- for option in item.options_with_values -%}
                                  <div class="product-option">
                                    <dd>
                                      {{ option.value -}}
                                      {%- unless forloop.last %}, {% endunless %}
                                    </dd>
                                  </div>
                                {%- endfor -%}
                              {%- endif -%}

                              {%- for property in item.properties -%}
                                {%- assign property_first_char = property.first | slice: 0 -%}
                                {%- if property.last != blank and property_first_char != '_' -%}
                                  <div class="product-option">
                                    <dt>{{ property.first }}:</dt>
                                    <dd>
                                      {%- if property.last contains '/uploads/' -%}
                                        <a
                                          href="{{ property.last }}"
                                          class="link"
                                          target="_blank"
                                          aria-describedby="a11y-new-window-message"
                                        >
                                          {{ property.last | split: '/' | last }}
                                        </a>
                                      {%- else -%}
                                        {{ property.last }}
                                      {%- endif -%}
                                    </dd>
                                  </div>
                                {%- endif -%}
                              {%- endfor -%}
                            </dl>

                            <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          {%- endif -%}

                          <ul
                            class="discounts list-unstyled"
                            role="list"
                            aria-label="{{ 'customer.order.discount' | t }}"
                          >
                            {%- for discount in item.line_level_discount_allocations -%}
                              <li class="discounts__discount">
                                <span class="svg-wrapper">{% render 'core-icon', name: 'discount' %}</span>
                                {{ discount.discount_application.title }}
                              </li>
                            {%- endfor -%}
                          </ul>
                          </div>

                                                  {%- liquid
                          assign has_qty_rules = false
                          if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                            assign has_qty_rules = true
                          endif

                          assign has_vol_pricing = false
                          if item.variant.quantity_price_breaks.size > 0
                            assign has_vol_pricing = true
                          endif
                        -%}
                        <div
                          class="cart-item__quantity {% if has_qty_rules or has_vol_pricing %} cart-item__quantity--info{% endif %}"
                          role="cell"
                          headers="CartDrawer-ColumnQuantity"
                        >
                          <quantity-popover>
                            <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                              <div class="quantity-popover-container{% if has_qty_rules or has_vol_pricing %} quantity-popover-container--hover{% endif %}">
                                <quantity-input class="quantity cart-quantity">
                                  <button
                                    class="quantity__button"
                                    name="minus"
                                    type="button"
                                    {% if item.instructions and item.instructions.can_update_quantity == false or item.quantity <= 1 %}
                                      disabled
                                    {% endif %}
                                  >
                                    <span class="visually-hidden">
                                      {{-
                                        'products.product.quantity.decrease'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <span class="svg-wrapper">
                                      {% render 'core-icon', name: 'minus' %}
                                    </span>
                                  </button>
                                  <input
                                    class="quantity__input"
                                    type="number"
                                    data-quantity-variant-id="{{ item.variant.id }}"
                                    name="updates[]"
                                    value="{{ item.quantity }}"
                                    {% # theme-check-disable %}
                                    data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                    min="0"
                                    data-min="{{ item.variant.quantity_rule.min }}"
                                    {% if item.variant.quantity_rule.max != null %}
                                      max="{{ item.variant.quantity_rule.max }}"
                                    {% endif %}
                                    step="{{ item.variant.quantity_rule.increment }}"
                                    {% # theme-check-enable %}
                                    aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                    id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                    data-index="{{ item.index | plus: 1 }}"
                                    {% if item.instructions and item.instructions.can_update_quantity == false %}
                                      disabled
                                    {% endif %}
                                  >
                                  <button
                                    class="quantity__button"
                                    name="plus"
                                    type="button"
                                    {% if item.instructions and item.instructions.can_update_quantity == false %}
                                      disabled
                                    {% endif %}
                                  >
                                    <span class="visually-hidden">
                                      {{-
                                        'products.product.quantity.increase'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <span class="svg-wrapper">
                                      {% render 'core-icon', name: 'plus' %}
                                    </span>
                                  </button>
                                </quantity-input>
                              </div>
                            </div>
                            {%- if has_qty_rules or has_vol_pricing -%}
                              <button
                                type="button"
                                class="quantity-popover__info-button quantity-popover__info-button--icon-with-label button button--tertiary"
                                aria-expanded="false"
                              >
                                <span class="svg-wrapper">{% render 'core-icon', name: 'info' %}</span>
                                <span>
                                  {%- if has_vol_pricing -%}
                                    {{ 'products.product.volume_pricing.note' | t }}
                                  {%- elsif has_qty_rules -%}
                                    {{ 'products.product.quantity.note' | t }}
                                  {%- endif -%}
                                </span>
                              </button>
                            {%- endif -%}
                            {%- if has_vol_pricing or has_qty_rules -%}
                              <div
                                class="cart-items__info global-settings-popup quantity-popover__info"
                                tabindex="-1"
                                hidden
                              >
                                {%- if has_qty_rules == false -%}
                                  <span class="volume-pricing-label caption">
                                    {{- 'products.product.volume_pricing.title' | t -}}
                                  </span>
                                {%- endif -%}
                                <div class="quantity__rules caption">
                                  {%- if item.variant.quantity_rule.increment > 1 -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.multiples_of'
                                        | t: quantity: item.variant.quantity_rule.increment
                                      -}}
                                    </span>
                                  {%- endif -%}
                                  {%- if item.variant.quantity_rule.min > 1 -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.min_of'
                                        | t: quantity: item.variant.quantity_rule.min
                                      -}}
                                    </span>
                                  {%- endif -%}
                                  {%- if item.variant.quantity_rule.max != null -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.max_of'
                                        | t: quantity: item.variant.quantity_rule.max
                                      -}}
                                    </span>
                                  {%- endif -%}
                                </div>
                                <button
                                  class="button-close button button--tertiary"
                                  type="button"
                                  aria-label="{{ 'accessibility.close' | t }}"
                                >
                                  <span class="svg-wrapper">{% render 'core-icon', name: 'close' %}</span>
                                </button>
                                {%- if item.variant.quantity_price_breaks.size > 0 -%}
                                  <volume-pricing class="parent-display">
                                    <ul class="list-unstyled">
                                      <li>
                                        <span>{{ item.variant.quantity_rule.min }}+</span>
                                        <span>{{ item.variant.price | money_with_currency }}/ea</span>
                                      </li>
                                      {%- for price_break in item.variant.quantity_price_breaks -%}
                                        <li>
                                          <span>
                                            {{- price_break.minimum_quantity -}}
                                            <span aria-hidden="true">+</span></span
                                          >
                                          <span>{{ price_break.price | money_with_currency }}/ea</span>
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </volume-pricing>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                            <div
                              id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                              class="cart-item__error"
                              role="alert"
                            >
                              <small class="cart-item__error-text"></small>
                              <span class="svg-wrapper">{% render 'core-icon', name: 'error' %}</span>
                            </div>
                          </quantity-popover>
                        </div>

                        </td>



                        
                        <td class="cart-item__totals right" role="cell" headers="CartDrawer-ColumnTotal">
                          <div class="icon-box">
                            <cart-remove-button
                              id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                            >
                              <button
                                  type="button"
                                  class=" button button--tertiary cart-remove-button"
                                  aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                                  data-variant-id="{{ item.variant.id }}"
                                  {% if item.instructions and item.instructions.can_remove == false %}
                                    class="hidden"
                                  {% endif %}
                                >
                                  <span class="svg-wrapper">
                                    {% render 'core-icon', name: 'trash' %}
                                  </span>
                                </button>
                              </cart-remove-button>
                              <button
                              type="button"
                              aria-label="Add to Wishlist"
                              class="swym-button swym-add-to-wishlist-view-product product_{{ item.product.id }} swym-bookmark wish-list"
                              data-with-epi="true"
                              data-swaction="addToWishlist"
                              data-product-id="{{ item.product.id }}"
                              data-variant-id="{{ item.variant.id }}"
                              data-product-url="{{ shop.url | append: item.product.url }}"
                            >
                              <span class="svg-wrapper wishlist-icon">{% render 'core-icon', name: 'wishlist', class: 'icon-wishlist' %}</span>
                              <span class="svg-wrapper wishlist-added-icon">{% render 'core-icon', name: 'wishlist-added', class: 'icon-wishlist-added' %}</span>
                            </button>
                          </div>

                          
                          {% comment %} {%- render 'loading-spinner' -%} {% endcomment %}
                          <div class="cart-item__price-wrapper">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <div class="cart-item__discounted-prices">
                                <span class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </span>
                                <s class="cart-item__old-price price price--end">
                                  {{ item.original_line_price | money }}
                                </s>
                                <span class="visually-hidden">
                                  {{ 'products.product.price.sale_price' | t }}
                                </span>
                                <span class="price price--end">
                                  {{ item.final_line_price | money }}
                                </span>
                              </div>
                            {%- else -%}
                              {%- if item.variant.compare_at_price > item.original_price -%}
                                <s class="cart-item__old-price price price--end">
                                  {{ item.variant.compare_at_price | times: item.quantity | money }}
                                </s>
                              {%- endif -%}
                              <span class="price price--end">
                                {{ item.original_line_price | money }}
                              </span>
                            {%- endif -%}

                            {%- if item.variant.available and item.unit_price_measurement -%}
                              {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                            {%- endif -%}
                          </div>
                          
                        </td>
                      </tr>
                      
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>
      {%- if cart != empty -%}
        <div class="custom-note hidden">
          <p>Don’t forget to save your code to use at checkout.</p>
        </div>
      {%- endif -%}
      </div>
      <div class="drawer__footer">
        {%- if cart != empty -%}
          {%- if settings.show_cart_note -%}
          <details id="Details-CartDrawer">
            <summary>
              <span class="summary__title">
                {{ 'sections.cart.note' | t }}
                <span class="svg-wrapper">{% render 'core-icon', name: 'caret' %}</span>
              </span>
            </summary>
            <cart-note class="cart__note field">
              <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
              <textarea
                id="CartDrawer-Note"
                class="text-area text-area--resize-vertical field__input"
                name="note"
                placeholder="{{ 'sections.cart.note' | t }}"
              >{{ cart.note }}</textarea>
            </cart-note>
          </details>
        {%- endif -%}

        <!-- Start blocks -->
        <!-- Subtotals -->

        <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
          {%- liquid
            assign total_compare_price = 0
            for item in cart.items
              if item.variant.compare_at_price > item.variant.price
                assign line_compare = item.variant.compare_at_price | times: item.quantity
              else
                assign line_compare = item.original_line_price
              endif
              assign total_compare_price = total_compare_price | plus: line_compare
            endfor
            assign total_saving = total_compare_price | minus: cart.total_price
          -%}

          <div class="totals-summary">
            <div class="totals-summary__item hidden">
              <span class="totals-summary__label">{{ 'sections.cart.subtotal' | t }}</span>
              <span class="totals-summary__value">{{ total_compare_price | money }}</span>
            </div>
            
            {%- if total_saving > 0 -%}
              <div class="totals-summary__item totals-summary__item--discount">
                <span class="totals-summary__label">{{ 'sections.cart.discount' | t }}</span>
                <s class="totals-summary__value">{{ total_saving | money }}</s>
              </div>
            {%- endif -%}

            <div class="totals totals-summary__item totals-summary__item--total" role="status">
              <h2 class="totals__total totals-summary__label">{{ 'sections.cart.estimated_total' | t }}</h2>
              <p class="totals__total-value totals-summary__value">{{ cart.total_price | money_with_currency }}</p>
            </div>
          </div>

          <small class="tax-note caption-large rte">
            {%- if cart.duties_included and cart.taxes_included -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included == false and cart.taxes_included -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included and cart.taxes_included == false -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- endif -%}
          </small>
        </div>

        <!-- CTAs -->

          <div class="cart__ctas" {{ block.shopify_attributes }}>
            <button
              type="submit"
              id="CartDrawer-Checkout"
              class="cart__checkout-button button"
              name="checkout"
              form="CartDrawer-Form"
              {% if cart == empty %}
                disabled
              {% endif %}
            >
              {{ 'sections.cart.checkout' | t }}
            </button>
          </div>
        {%- endif -%}
      </div>
      
      <div class="drawer__wishlist-content">
        <div class="drawer__contents">
          <div id="WishlistDrawerContent">
            <!-- Include html in the body -->
            <div id="swym-wishlist-render-container"></div>
          </div>
          {%- for block in section.blocks -%}
            {%- if block.type == '@app' -%}
              {% render block %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<script>
  (function() {
    function updateEmptyState() {
      const counterEl = document.querySelector('.wishlist-count-js');
      const wishlistContent = document.querySelector('.drawer__wishlist-content');
      if (!counterEl || !wishlistContent) return;

      const text = counterEl.textContent.trim();
      const countMatch = text.match(/\d+/);
      const count = countMatch ? parseInt(countMatch[0], 10) : 0;

      wishlistContent.classList.toggle('empty', count === 0);
    }

    function init() {
      const counterEl = document.querySelector('.wishlist-count-js');
      if (!counterEl) return;

      updateEmptyState();

      const obs = new MutationObserver(updateEmptyState);
      obs.observe(counterEl, { childList: true, characterData: true, subtree: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
