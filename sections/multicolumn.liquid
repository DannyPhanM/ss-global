{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile}}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section-{{ section.id }}-padding slider-component {
    --desktop-margin-left-first-item: 0rem;
  }
  .section-{{ section.id }}-padding .slider--desktop {
    scroll-padding-left: 0rem;
  }
  .section-{{ section.id }}-padding .slider--desktop .slider__slide:first-child {
    margin-left: 0rem;
    scroll-margin-left: 0rem;
  }
  .section-{{ section.id }}-padding .slider--desktop:after {
    padding-left: 0rem;
  }
  .section-{{ section.id }}-padding .slider--desktop.grid--1-col-desktop .grid__item {
    width: 100%;
    max-width: 100%;
  }
  .section-{{ section.id }}-padding .slider--desktop.grid--2-col-desktop .grid__item {
    width: calc(50% - var(--grid-desktop-horizontal-spacing) / 2);
  }
  .section-{{ section.id }}-padding .slider--desktop.grid--3-col-desktop .grid__item {
    width: calc(33.33% - var(--grid-desktop-horizontal-spacing) * 2 / 3);
  }
  .section-{{ section.id }}-padding .slider--desktop.grid--4-col-desktop .grid__item {
    width: calc(25% - var(--grid-desktop-horizontal-spacing) * 3 / 4);
  }
  .multicolumn-card__info.content_overlay {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
}
.multicolumn-card__info.content_overlay * {
    color: #fff !important;
    line-height: 1.4 !important;
}
.multicolumn-card__info.content_overlay {
    pointer-events: none;
    z-index: 12;
}
.multicolumn-card__info.content_overlay > * {
    pointer-events: auto;
}
.multicolumn-card__info .link {
  z-index: 12;
  position: relative;
}
.multicolumn-card__info.content_overlay.left-top {
    justify-content: flex-start;
    text-align: flex-start;
}
.multicolumn-card__info.content_overlay.left-center {
    justify-content: center;
    text-align: flex-start;
}
.multicolumn-card__info.content_overlay.left-bottom {
    justify-content: flex-end;
    text-align: flex-start;
}
.multicolumn-card__info.content_overlay.center-top {
    justify-content: flex-start;
    text-align: center;
}
.multicolumn-card__info.content_overlay.center-center {
    justify-content: center;
    text-align: center;
}
.multicolumn-card__info.content_overlay.center-bottom {
    justify-content: flex-end;
    text-align: center;
}
.multicolumn-card__info.content_overlay.right-top {
    justify-content: flex-start;
        align-items: flex-end;
    text-align: right;
}
.multicolumn-card__info.content_overlay.right-center {
    justify-content: center;
        align-items: flex-end;
    text-align: right;
}
.multicolumn-card__info.content_overlay.right-bottom {
    justify-content: flex-end;
       align-items: flex-end;
    text-align: right;
}

.multicolumn-card__image-wrapper .has-image-mobile .multicolumn-card__image--mobile {
    display: none;
}

{%- liquid
  assign desktop_ratio = section.settings.image_ratio
  assign mobile_ratio = section.settings.image_ratio_mobile

  case desktop_ratio
    when '1/1'
      assign desktop_padding = '100%'
    when '2/3'
      assign desktop_padding = '150%'
    when '3/2'
      assign desktop_padding = '66.66%'
    when '4/5'
      assign desktop_padding = '125%'
    when '16/9'
      assign desktop_padding = '56.25%'
    when '9/16'
      assign desktop_padding = '177.77%'
    when 'square'
      assign desktop_padding = '100%'
    when 'portrait'
      assign desktop_padding = '150%'
    when 'circle'
      assign desktop_padding = '100%'
    when 'adapt'
      assign highest_ratio = 0
      for block in section.blocks
        if block.settings.image.aspect_ratio > highest_ratio
          assign highest_ratio = block.settings.image.aspect_ratio
        endif
      endfor
      if highest_ratio == 0
        assign highest_ratio = 1
      endif
      assign desktop_padding = 1 | divided_by: highest_ratio | times: 100 | append: '%'
  endcase

  case mobile_ratio
    when '1/1'
      assign mobile_padding = '100%'
    when '2/3'
      assign mobile_padding = '150%'
    when '3/2'
      assign mobile_padding = '66.66%'
    when '4/5'
      assign mobile_padding = '125%'
    when '16/9'
      assign mobile_padding = '56.25%'
    when '9/16'
      assign mobile_padding = '177.77%'
    when 'square'
      assign mobile_padding = '100%'
    when 'portrait'
      assign mobile_padding = '150%'
    when 'circle'
      assign mobile_padding = '100%'
    when 'adapt'
      assign highest_ratio_mobile = 0
      for block in section.blocks
        assign image_mobile = block.settings.image_mobile | default: block.settings.image
        if image_mobile.aspect_ratio > highest_ratio_mobile
          assign highest_ratio_mobile = image_mobile.aspect_ratio
        endif
      endfor
      if highest_ratio_mobile == 0
        assign highest_ratio_mobile = 1
      endif
      assign mobile_padding = 1 | divided_by: highest_ratio_mobile | times: 100 | append: '%'
  endcase
-%}

@media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding .media {
    padding-bottom: {{ desktop_padding }};
  }
}

@media only screen and (max-width: 749px) {
  .section-{{ section.id }}-padding .media {
    padding-bottom: {{ mobile_padding }} !important;
  }
    .multicolumn-card__image-wrapper .has-image-mobile .multicolumn-card__image {
        display: none;
    }
    .multicolumn-card__image-wrapper .has-image-mobile .multicolumn-card__image--mobile {
        display: block;
    }
}
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and section.blocks.size > section.settings.columns_desktop
    assign show_desktop_slider = true
  endif
-%}

<div class="multicolumn color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %}">
  <div
    class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin multicolumn__title">
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
        {%- if section.settings.button_label != blank and show_mobile_slider -%}
          <a href="{{ section.settings.button_link }}" class="link underlined-link large-up-hide">
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}
    <slider-component class="slider-mobile-gutter{% if show_desktop_slider %} slider-component-desktop{% endif %}">
      <ul
        class="multicolumn-list {% if section.settings.remove_space_x %}remove-space-x {% endif %} contains-content-container grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% if show_mobile_slider %} slider slider--tablet grid--peek{% endif %}{% if show_desktop_slider %} slider slider--desktop slider--no-overflow{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- for block in section.blocks -%}
        {%- assign heading_tag = block.settings.heading_tag | default: 'h2' -%}
          {%- assign empty_column = '' -%}
          {%- if block.settings.image == blank
            and block.settings.title == blank
            and block.settings.text == blank
            and block.settings.link_label == blank
          -%}
            {%- assign empty_column = ' multicolumn-list__item--empty' -%}
          {%- endif -%}

          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="multicolumn-list__item grid__item{% if section.settings.swipe_on_mobile or section.settings.enable_desktop_slider %} slider__slide{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %}{{ empty_column }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
              <div class="multicolumn-card content-container">
                {%- liquid
                  assign spaced_image = false
                  if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle'
                    assign spaced_image = true
                  endif
                -%}
                {%- if block.settings.link != blank and block.settings.image_link -%}
                  <a href="{{ block.settings.link }}" class="media_link"></a>
                {%- endif -%}
                <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width{% if section.settings.image_width != 'full' or spaced_image %} {% unless block.settings.content_overlay %}multicolumn-card-spacing{%endunless%}{% endif %}">
                  <div
                    class="{% if block.settings.image_mobile  %} has-image-mobile {% endif %} media media--transparent media--{{ section.settings.image_ratio }}"
                  >
                  {%- if block.settings.image != blank or block.settings.image_mobile != blank -%}
                    {%- liquid
                      assign number_of_columns = section.settings.columns_desktop
                      assign number_of_columns_mobile = section.settings.columns_mobile
                      assign grid_space_desktop = number_of_columns | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_tablet = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_mobile = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | divided_by: 2 | plus: 30 | append: 'px'
                      if section.settings.image_width == 'half'
                        assign image_width = 0.5
                      elsif section.settings.image_width == 'third'
                        assign image_width = 0.33
                      else
                        assign image_width = 1
                      endif
                    -%}
                    {% capture sizes %}
                      (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) * {{ image_width }} /  {{ number_of_columns }}),
                      (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                      (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) * {{ image_width }} / {{ number_of_columns_mobile }}),
                      calc((100vw - {{ grid_space_mobile }}) * {{ image_width }} / {{ number_of_columns_mobile }})
                    {% endcapture %}
                    {%- if block.settings.image != blank -%}
                      {{
                        block.settings.image
                        | image_url: width: 3200
                        | image_tag:
                          widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                          sizes: sizes,
                          class: 'multicolumn-card__image',
                          draggable: false
                      }}
                    {%- endif -%}
                    {% if block.settings.image_mobile %}
                      {{
                        block.settings.image_mobile
                        | image_url: width: 3200
                        | image_tag:
                          widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                          sizes: sizes,
                          class: 'multicolumn-card__image--mobile',
                          draggable: false
                      }}
                    {% endif %}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              </div>
              <div class="multicolumn-card__info {% if block.settings.content_overlay %} content_overlay {{ block.settings.content_alignment }} {% endif %}">
                {%- if block.settings.title != blank -%}
                  <{{ heading_tag }} class="inline-richtext">{{ block.settings.title }}</{{ heading_tag }}>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.link_label != blank -%}
                  <a
                    class="link animate-arrow"
                    {% if block.settings.link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                  >
                    {{- block.settings.link_label | escape -}}
                    <span class="svg-wrapper"
                      ><span class="icon-wrap">&nbsp;{% render 'core-icon', name: 'arrow' %}</span></span
                    >
                  </a>
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_mobile_slider or show_desktop_slider -%}
        <div class="slider-buttons no-js-hidden{% unless show_desktop_slider %} large-up-hide{% endunless %}">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="9" height="22" viewBox="0 0 9 22" fill="none">
                <path d="M0.857422 0.514648L6.85742 10.5146L0.857422 20.5146" stroke="#999999" stroke-width="1"/>
              </svg>
            </span>
          </button>
          
          {%- unless section.settings.show_dots -%}
            <div class="slider-counter caption">
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ section.blocks.size }}</span>
            </div>
          {%- endunless -%}

          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="9" height="22" viewBox="0 0 9 22" fill="none">
                <path d="M0.857422 0.514648L6.85742 10.5146L0.857422 20.5146" stroke="#999999" stroke-width="1"/>
              </svg>
            </span>
          </button>
        </div>

        {%- if section.settings.show_dots -%}
          <slider-component-dots class="slider-dots">
            {%- for block in section.blocks -%}
              <button class="slider-dot" data-index="{{ forloop.index | minus: 1 }}" aria-label="Go to slide {{ forloop.index }}"></button>
            {%- endfor -%}
          </slider-component-dots>
        {%- endif -%}
      {%- endif -%}
    </slider-component>
    <div class="center{% if show_mobile_slider %} small-hide medium-hide{% endif %}">
      {%- if section.settings.button_label != blank -%}
        <a
          class="button button--primary"
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{%- if show_mobile_slider or show_desktop_slider -%}
  {%- if section.settings.show_dots -%}
    <script>
      (function() {
        if (customElements.get('slider-component-dots')) return;

        customElements.define('slider-component-dots', class SliderComponentDots extends HTMLElement {
          constructor() {
            super();
          }

          connectedCallback() {
            // Đợi một chút để slider cha kịp khởi tạo
            setTimeout(() => {
              this.sliderComponent = this.closest('slider-component');
              if (!this.sliderComponent) return;

              this.dots = this.querySelectorAll('.slider-dot');
              
              this.sliderComponent.addEventListener('slideChanged', (event) => {
                this.updateDots(event.detail.currentPage - 1);
              });

              this.dots.forEach(dot => {
                dot.addEventListener('click', (e) => {
                  const index = parseInt(dot.dataset.index);
                  if (this.sliderComponent.sliderItemOffset) {
                    this.sliderComponent.setSlidePosition(index * this.sliderComponent.sliderItemOffset);
                  }
                });
              });
              
              // Cập nhật ngay lập tức dựa trên page hiện tại của slider
              this.updateDots((this.sliderComponent.currentPage || 1) - 1);
            }, 50);
          }

          updateDots(activeIndex) {
            if (!this.dots) return;
            this.dots.forEach((dot, index) => {
              const isActive = index === activeIndex;
              dot.setAttribute('aria-current', isActive ? 'true' : 'false');
              if (isActive) {
                dot.classList.add('active');
              } else {
                dot.classList.remove('active');
              }
            });
          }
        });
      })();
    </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "remove_space_x",
      "label": "remove space horizon",
      "default": false
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.multicolumn.settings.title.default",
      "label": "t:sections.multicolumn.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_image.content"
    },    
    {
      "type": "select",
      "id": "image_width",
      "options": [
        {
          "value": "third",
          "label": "t:sections.multicolumn.settings.image_width.options__1.label"
        },
        {
          "value": "half",
          "label": "t:sections.multicolumn.settings.image_width.options__2.label"
        },
        {
          "value": "full",
          "label": "t:sections.multicolumn.settings.image_width.options__3.label"
        }
      ],
      "default": "full",
      "label": "t:sections.multicolumn.settings.image_width.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.multicolumn.settings.image_ratio.options__1.label"
        },
        {
          "value": "1/1",
          "label": "1/1"
        },
        {
          "value": "2/3",
          "label": "2/3"
        },
        {
          "value": "3/2",
          "label": "3/2"
        },
        {
          "value": "4/5",
          "label": "4/5"
        },
        {
          "value": "16/9",
          "label": "16/9"
        },
        {
          "value": "9/16",
          "label": "9/16"
        },
        {
          "value": "circle",
          "label": "t:sections.multicolumn.settings.image_ratio.options__4.label"
        }
      ],
      "default": "4/5",
      "label": "Desktop image ratio"
    },
    {
      "type": "select",
      "id": "image_ratio_mobile",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "1/1",
          "label": "1/1"
        },
        {
          "value": "2/3",
          "label": "2/3"
        },
        {
          "value": "3/2",
          "label": "3/2"
        },
        {
          "value": "4/5",
          "label": "4/5"
        },
        {
          "value": "16/9",
          "label": "16/9"
        },
        {
          "value": "9/16",
          "label": "9/16"
        },
        {
          "value": "circle",
          "label": "Circle"
        }
      ],
      "default": "4/5",
      "label": "Mobile image ratio"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_button.content"
    },    
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.multicolumn.settings.button_label.default",
      "label": "t:sections.multicolumn.settings.button_label.label", 
      "info": "t:sections.multicolumn.settings.button_label.info"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.multicolumn.settings.button_link.label"
    },    
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_layout.content"
    },     
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.multicolumn.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.multicolumn.settings.column_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.multicolumn.settings.column_alignment.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.multicolumn.settings.column_alignment.label"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "Enable slider on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "select",
      "id": "background_style",
      "options": [
        {
          "value": "none",
          "label": "t:sections.multicolumn.settings.background_style.options__1.label"
        },
        {
          "value": "primary",
          "label": "t:sections.multicolumn.settings.background_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.multicolumn.settings.background_style.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },    
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__1.label"
        },
