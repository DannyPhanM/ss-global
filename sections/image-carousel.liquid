{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'section-image-carousel.css' | asset_url | stylesheet_tag }}

{%- if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.image != blank -%}
  {%- style -%}
  .image-carousel-section .banner__media,
  .image-carousel-section .media>*:not(.zoom):not(.deferred-media__poster-button),
  .image-carousel-section .media model-viewer {
    position: relative;
  }

    /* Force swiper to follow aspect ratio height */
    #Swiper-{{ section.id }} .swiper-wrapper,
    #Swiper-{{ section.id }} .swiper-slide {
      height: 100%;
    }
  {%- endstyle -%}
{%- endif -%}

<!-- Swiper CSS/JS -->
{%- style -%}
  @media screen and (max-width: 749px) {
    .image-carousel--full-width-mobile {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }
  }
{%- endstyle -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<div class="page-width image-carousel{% if section.settings.full_width_mobile %} image-carousel--full-width-mobile{% endif %}">
  <div class="image-carousel-section slideshow-component">
    {%- if section.blocks.size > 1 -%}
      <div class="slideshow__controls slider-buttons">
        <button
          type="button"
          class="slider-button slider-button--prev swiper-button-prev-{{ section.id }}"
          aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        >
              <span class="svg-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" width="9" height="22" viewBox="0 0 9 22" fill="none">
                  <path d="M0.857422 0.514648L6.85742 10.5146L0.857422 20.5146" stroke="#999999" stroke-width="1"/>
                </svg>
              </span>
        </button>
        {%- if section.settings.show_dots -%}
          <div class="slider-counter slider-counter--dots swiper-pagination-{{ section.id }}"></div>
        {%- endif -%}
        <button
          type="button"
          class="slider-button slider-button--next swiper-button-next-{{ section.id }}"
          aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        >
              <span class="svg-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" width="9" height="22" viewBox="0 0 9 22" fill="none">
                  <path d="M0.857422 0.514648L6.85742 10.5146L0.857422 20.5146" stroke="#999999" stroke-width="1"/>
                </svg>
              </span>
        </button>
      </div>
    {%- endif -%}

    <div
      class="swiper swiper-image-carousel-{{ section.id }} banner banner--{{ section.settings.slide_height }} slideshow"
      id="Swiper-{{ section.id }}"
    >
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div
            class="swiper-slide slideshow__slide"
            {{ block.shopify_attributes }}
          >
            <div class="image-carousel-item">
              {%- if block.settings.link_image and block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="image-carousel-link-overlay"></a>
              {%- endif -%}
              
              <div class="slideshow__media banner__media media{% if block.settings.image == blank %} placeholder{% endif %}">
                {%- if block.settings.image -%}
                  {%- liquid
                    assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                    assign sizes = '100vw'
                    assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                  -%}
                  <picture>
                    {%- if block.settings.mobile_image -%}
                      <source media="(max-width: 749px)" srcset="{{ block.settings.mobile_image | image_url: width: 1500 }}" sizes="100vw">
                    {%- endif -%}
                    {{
                      block.settings.image
                      | image_url: width: 3840
                      | image_tag: height: height, sizes: sizes, widths: widths, loading: 'lazy'
                    }}
                  </picture>
                {%- else -%}
                  {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="image-carousel-content-container">
      <div class="image-carousel-content {{ section.settings.text_alignment }}">
        <div class="image-carousel-text-overlay">
          {%- if section.settings.subheading != blank -%}
            <p class="image-carousel-subheading h4">{{ section.settings.subheading }}</p>
          {%- endif -%}
          
          {%- if section.settings.heading != blank -%}
            <h2 class="image-carousel-heading {{ section.settings.heading_size }}">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="image-carousel-description rte">
              {{ section.settings.text }}
            </div>
          {%- endif -%}

          <div class="image-carousel-buttons">
            {%- if section.settings.button_1_label != blank -%}
              <a
                href="{{ section.settings.button_1_link | default: '#' }}"
                class=" button--{{ section.settings.button_1_style }}"
              >
                {{ section.settings.button_1_label }}
              </a>
            {%- endif -%}
            {%- if section.settings.button_2_label != blank -%}
              <a
                href="{{ section.settings.button_2_link | default: '#' }}"
                class=" button--{{ section.settings.button_2_style }}"
              >
                {{ section.settings.button_2_label }}
              </a>
            {%- endif -%}
            {%- if section.settings.button_3_label != blank -%}
              <a
                href="{{ section.settings.button_3_link | default: '#' }}"
                class=" button--{{ section.settings.button_3_style }}"
              >
                {{ section.settings.button_3_label }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const swiper = new Swiper('.swiper-image-carousel-{{ section.id }}', {
      loop: {{ section.settings.loop | default: true }},
      observer: true,
      observeParents: true,
      {% if section.settings.auto_rotate %}
      autoplay: {
        delay: {{ section.settings.change_slides_speed | times: 1000 }},
        disableOnInteraction: false,
      },
      {% endif %}
      navigation: {
        nextEl: '.swiper-button-next-{{ section.id }}',
        prevEl: '.swiper-button-prev-{{ section.id }}',
      },
      pagination: {
        el: '.swiper-pagination-{{ section.id }}',
        clickable: true,
        renderBullet: function (index, className) {
          return '<span class="' + className + ' slider-counter__link slider-counter__link--dots"><span class="dot"></span></span>';
        },
      },
      slidesPerView: 1,
      spaceBetween: 0,
      speed: 600,
    });
  });
</script>
</div>

{% schema %}
{
  "name": "Image Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width_mobile",
      "label": "Full width on mobile",
      "default": false
    },
    {
      "type": "select",
      "id": "slide_height",
      "options": [
        { "value": "adapt_image", "label": "Adapt to first image" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full_screen", "label": "Full screen" }
      ],
      "default": "medium",
      "label": "Slider height"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Enable loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show navigation dots",
      "default": true
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 2,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Content Box"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "NEW COLLECTION"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Exquisite Designs"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Discover our latest collection featuring handcrafted details and premium materials.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        { "value": "left-top", "label": "Left Top" },
        { "value": "left-center", "label": "Left Middle" },
        { "value": "left-bottom", "label": "Left Bottom" },
        { "value": "center-top", "label": "Center Top" },
        { "value": "center-center", "label": "Center Middle" },
        { "value": "center-bottom", "label": "Center Bottom" },
        { "value": "right-top", "label": "Right Top" },
        { "value": "right-center", "label": "Right Middle" },
        { "value": "right-bottom", "label": "Right Bottom" }
      ],
      "default": "left-top",
      "label": "Content alignment"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "select",
      "id": "button_1_style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "primary",
      "label": "Button 1 Style"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 label"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    },
    {
      "type": "select",
      "id": "button_2_style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "secondary",
      "label": "Button 2 Style"
    },
    {
      "type": "header",
      "content": "Button 3"
    },
    {
      "type": "text",
      "id": "button_3_label",
      "label": "Button 3 label"
    },
    {
      "type": "url",
      "id": "button_3_link",
      "label": "Button 3 link"
    },
    {
      "type": "select",
      "id": "button_3_style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "outline",
      "label": "Button 3 Style"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image (optional)"
        },
        {
          "type": "checkbox",
          "id": "link_image",
          "label": "Enable Link on Image",
          "default": false
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Carousel",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
